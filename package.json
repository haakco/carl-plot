    "@react-three/fiber": "^9.5.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-store": "^0.9.3",
    "@tanstack/store": "^0.9.3",
    "@use-gesture/react": "^10.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "complex.js": "^2.4.3",
