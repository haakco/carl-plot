{
  "name": "complex-explorer",
  "version": "0.1.0",
  "description": "Interactive complex function explorer — drag poles and zeros, see real-time domain coloring",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && cp dist/client/index.html dist/client/404.html",
    "preview": "vite preview",
    "lint": "pnpm biome check src/ && pnpm lint:duplicates",
    "lint:fix": "pnpm biome check --write src/",
    "lint:typecheck": "tsc --noEmit",
    "lint:duplicates": "jscpd src/ --threshold 5",
    "test": "echo \"TODO: vitest\" && exit 0"
  },
  "keywords": [
    "complex-analysis",
    "domain-coloring",
    "webgl",
    "math-visualization"
